# eid0l0n — example environment file
#
# DO NOT EDIT THIS FILE WITH REAL KEYS.
# Copy to ~/.config/eidolon/env (mode 600) or to .env in your shell, then fill in
# whichever lines apply to the backend(s) you want to use.
#
# eid0l0n auto-detects 6 image-gen backends. You only need ONE configured.
# Priority order (first available wins): codex → gemini → openai → fal → replicate → openrouter
#
# To see what's currently detected:
#     python3 scripts/setup.py detect-backends
#
# To force a specific backend (overrides auto-pick):
#     EIDOLON_IMAGE_BACKEND=gemini

# ─── Backend 1: codex / ChatGPT OAuth (FREE for Plus/Pro/Team) ───────────────
#
# No env var needed — eid0l0n reads ~/.codex/auth.json directly.
# Just run `codex login` once in your shell. That's it.
#
# Optional quality knob (applies to codex and openai backends):
# EIDOLON_IMAGE_QUALITY=medium      # low | medium | high
# EIDOLON_IMAGE_ASPECT=square       # square | portrait | landscape

# ─── Backend 2: gemini (Google AI Studio — free tier available) ──────────────
# GEMINI_API_KEY=AIza-REPLACE
# EIDOLON_GEMINI_MODEL=gemini-2.5-flash-image-preview

# ─── Backend 3: openai (Images API — gpt-image-2) ────────────────────────────
# OPENAI_API_KEY=sk-REPLACE
# OPENAI_IMAGE_MODEL=gpt-image-2

# ─── Backend 4: fal.ai ───────────────────────────────────────────────────────
# FAL_KEY=REPLACE
# EIDOLON_FAL_MODEL=fal-ai/nano-banana             # text-to-image default
# EIDOLON_FAL_MODEL=fal-ai/nano-banana/edit        # img2img variant

# ─── Backend 5: Replicate ────────────────────────────────────────────────────
# REPLICATE_API_TOKEN=r8_REPLACE
# EIDOLON_REPLICATE_MODEL=black-forest-labs/flux-kontext-pro    # img2img default
# EIDOLON_REPLICATE_MODEL=black-forest-labs/flux-1.1-pro        # text-to-image

# ─── Backend 6: OpenRouter (legacy default) ──────────────────────────────────
#
# Bearer token for the OpenRouter image API. Mode 600 strongly recommended.
# Use `setup.py set-api --key <KEY>` to write this safely under ~/.config/eidolon/env.
# IMAGE_API_KEY=sk-REPLACE
# IMAGE_API_BASE_URL=https://openrouter.ai/api/v1
# IMAGE_API_MODELS=google/gemini-2.5-flash-image-preview,google/gemini-2.5-flash

# ─── Path overrides (optional) ───────────────────────────────────────────────
# EIDOLON_VISUAL_ANCHOR=~/.config/eidolon/visual_anchor.md
# EIDOLON_REFERENCE=~/.config/eidolon/reference.jpg
# EIDOLON_OUTPUT_DIR=~/Pictures/eidolon
