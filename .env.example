# eid0l0n — example environment file
#
# DO NOT EDIT THIS FILE WITH REAL KEYS.
# Copy to ~/.config/eid0l0n/env (mode 600) or to .env in your shell, then fill in.
# The setup wizard (`python3 scripts/setup.py`) writes this file for you.

# ─── Required ────────────────────────────────────────────────────────────────

# Bearer token for the image API. Never commit. Mode 600 strongly recommended.
IMAGE_API_KEY=sk-REPLACE-WITH-YOUR-KEY

# ─── Optional ────────────────────────────────────────────────────────────────

# OpenAI-compatible base URL. Default: https://openrouter.ai/api/v1
# IMAGE_API_BASE_URL=https://openrouter.ai/api/v1

# Comma-separated model fallback chain. First model is tried first.
# IMAGE_API_MODELS=google/gemini-2.5-flash-image-preview,google/gemini-2.5-flash

# Override persona / reference / output paths (defaults usually fine).
# EID0L0N_PERSONA=~/.config/eid0l0n/persona.md
# EID0L0N_REFERENCE=~/.config/eid0l0n/reference.jpg
# EID0L0N_OUTPUT_DIR=~/Pictures/eid0l0n
