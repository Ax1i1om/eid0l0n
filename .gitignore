# Secrets — NEVER commit. The wizard writes ~/.config/eidolon/<agent>/env
# (mode 600); this glob covers anyone who copies it into the repo by mistake.
.env
.env.*
!.env.example
env
config.local.json
secrets.json

# A real persona / visual anchor belongs at ~/.config/eidolon/<agent>/, not in
# the repo. The shipped example is references/persona.example.md and IS committed.
persona.md
visual_anchor.md
/persona.md
/visual_anchor.md

# Candidate reference images generated during onboarding loop
/candidates/
cand-*.png

# Reference images — user supplies their own; never commit.
reference.jpg
reference.jpeg
reference.png
reference.webp
/assets/reference.*

# Generated images
/output/
*.generated.png
*.generated.jpg

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Editors / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# uv / pip
.uv/
*.lock
